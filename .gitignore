# ===========================================================

#  RONDINES / GORATRACK — .gitignore
# ============================================================

# ------------------------------------------------------------
# 🔴 CRÍTICO: Credenciales y configuración sensible
# ------------------------------------------------------------
api/db.php
*.env
.env.*
config.local.php
secrets.php

# ------------------------------------------------------------
# 📁 Archivos subidos por usuarios (fotografías de incidentes)
# ------------------------------------------------------------
uploads/

# ------------------------------------------------------------
# 📋 Documentación interna de arquitectura
# ------------------------------------------------------------
context.md

# ------------------------------------------------------------
# 🛠 Archivos de entorno de desarrollo (editor / IDE)
# ------------------------------------------------------------
.vscode/
*.code-workspace
.idea/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------
# 💻 Sistema operativo
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# 📦 Dependencias (si en algún momento se agrega Node/Composer)
# ------------------------------------------------------------
node_modules/
vendor/
